# ── Database ──────────────────────────────────────────────────────────────────
# Neon PostgreSQL connection string (asyncpg driver)
DATABASE_URL=postgresql+asyncpg://user:password@host/credo

# Separate test database — used by pytest integration tests
TEST_DATABASE_URL=postgresql+asyncpg://user:password@host/credo_test

# ── Redis (ARQ task queue) ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-random-hex-string

# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-with-fernet-base64-key

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Create app at https://github.com/settings/developers
# PAUSE: provide these before running F1 GitHub OAuth or F2 GitHub Agent tasks
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8000/auth/github/callback

# ── AI APIs ───────────────────────────────────────────────────────────────────
# PAUSE: provide before running F2 Document Agent (Week 2) or F6 SimuHire (Week 3)
# Groq free tier: https://console.groq.com — covers AI detection (llama-3.1-8b-instant)
# and audio transcription (whisper-large-v3-turbo)
GROQ_API_KEY=
ANTHROPIC_API_KEY=

# ── App ───────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
MAX_UPLOAD_SIZE_MB=10
